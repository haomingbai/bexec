# @details
# Defines repository-level ignore rules for CMake build trees, compiled
# objects, libraries, executables, and local test output.

build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Testing/
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe
*.swp
.tmp/
.cache/
.artifacts/
